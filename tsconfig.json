{
  "compilerOptions": {
    "target": "ES2025",
    "module": "commonjs",
    "lib": ["ES2025", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "outDir": "dist",
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": ["**/*.ts"],
  "exclude": [
    "node_modules",
    ".features-gen",
    "dist",
    "playwright-report",
    "test-results"
  ]
}
